{% macro estimateFunctionReadWrite(variable) %}
  {% if 'cachevariable' in variable.tag %}
    {% if variable.get('addressSpaceWrite') == 'forbidden' %}
      read-only
    {% else %}
      read+write
    {% endif %}
  {% else %}
    {% if variable.get('addressSpaceWrite') == 'forbidden' and variable.get('addressSpaceRead') == 'forbidden' %}
      none
    {% elif variable.get('addressSpaceWrite') == 'forbidden' and variable.get('addressSpaceRead') != 'forbidden' %}
      read-only
    {% elif variable.get('addressSpaceWrite') != 'forbidden' and variable.get('addressSpaceRead') == 'forbidden' %}
      write-only
    {% elif variable.get('addressSpaceWrite') != 'forbidden' and variable.get('addressSpaceRead') != 'forbidden' %}
      read+write
    {% endif %}
  {% endif %}
{% endmacro %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OPC UA address space documentation — {{designInspector.getProjectName()}}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; max-width: 960px; margin: 0 auto; padding: 1em; color: #333; }
    h1 { border-bottom: 2px solid #4a90d9; padding-bottom: 0.3em; }
    h2 { border-top: 2px solid #ddd; padding-top: 0.8em; margin-top: 1.5em; }
    h3 { margin-top: 1em; margin-bottom: 0.3em; color: #555; font-size: 1em; }
    a { color: #4a90d9; text-decoration: none; }
    a:hover { text-decoration: underline; }
    code { background: #f4f4f4; padding: 1px 4px; border-radius: 3px; font-size: 0.9em; }
    li { margin-bottom: 8pt; }
    .top-link { font-size: 0.8em; float: right; }
    .jump-index { margin: 1em 0; }
    .jump-index a { display: inline-block; margin: 2px 6px 2px 0; padding: 2px 8px; background: #f0f4f8; border-radius: 3px; font-size: 0.9em; }
    .label { font-weight: bold; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.5px; margin-right: 0.5em; }
    .label-doc { color: #3366aa; }
    .doc { background-color: #f0f4fa; border-left: 3px solid #4a90d9; padding: 6px 10px; margin: 4px 0; }
    .var-meta { font-size: 0.85em; color: #666; }
    .badge-cache { background: #e8f0e8; color: #2a6e2a; padding: 1px 6px; border-radius: 3px; font-size: 0.8em; }
    .badge-source { background: #fff0e0; color: #a06020; padding: 1px 6px; border-radius: 3px; font-size: 0.8em; }
    .badge-access { background: #f0f0f0; color: #555; padding: 1px 6px; border-radius: 3px; font-size: 0.8em; }
    .children { margin-top: 0.5em; }
    .children a { display: inline-block; margin: 2px 6px 2px 0; padding: 2px 8px; background: #f0f4f8; border-radius: 3px; font-size: 0.9em; }
    .no-components { color: #888; font-style: italic; margin: 0.5em 0; }
  </style>
</head>
<body>
<h1>OPC UA address space documentation for {{designInspector.getProjectName()}}</h1>

<div class="jump-index">
{% for class_name in designInspector.get_names_of_all_classes()|sort %}
{% set cls = designInspector.objectify_class(class_name) %}
  <a href="#class_{{cls.get('name')}}">{{cls.get('name')}}</a>
{% endfor %}
</div>

{% for class_name in designInspector.get_names_of_all_classes()|sort %}
{% set cls = designInspector.objectify_class(class_name) %}
  <h2 id="class_{{cls.get('name')}}">{{cls.get('name')}} <a href="#" class="top-link">[top]</a></h2>

  {# per-class documentation #}
  {% if cls.documentation|length>0 %}
    <div class="doc"><span class="label label-doc">Doc</span>
        {{cls.documentation|node_text_contents_to_string}}
    </div>
  {% endif %}

  {% if (cls.cachevariable|length + cls.sourcevariable|length + cls.method|length)>0 %}
    {% if (cls.cachevariable|length + cls.sourcevariable|length)>0 %}
      <h3>Variables</h3>
      <ul>
        {% set variables = designInspector.to_list_if_exists(cls.cachevariable) + designInspector.to_list_if_exists(cls.sourcevariable) %}
        {% for variable in variables|sorted_by_objectified_attr('name') %}
          <li>
            <b>{{variable.get('name')}}</b>
            <span class="var-meta">{{variable.get('dataType')}}</span>
            {% if 'cachevariable' in variable.tag %}
              <span class="badge-cache">cache</span>
            {% else %}
              <span class="badge-source">source</span>
            {% endif %}
            <span class="badge-access">{{estimateFunctionReadWrite(variable)}}</span>
            {% if variable.documentation|length>0 %}
              <div class="doc"><span class="label label-doc">Doc</span>
                {{variable.documentation|node_text_contents_to_string}}
              </div>
            {% endif %}
          </li>
          {% endfor %}
      </ul>
    {% endif %}
    {% if cls.method|length>0 %}
    <h3>Methods</h3>
      <ul>
        {% for m in cls.method|sorted_by_objectified_attr('name') %}
          <li>
              <b>{{m.get('name')}}</b>
              {% if m.documentation|length>0 %}
                <div class="doc"><span class="label label-doc">Doc</span>
                  {{m.documentation|node_text_contents_to_string}}
                </div>
              {% endif %}
              {% if m.argument|length>0 %}
                <br/>
                Arguments:
                <ul>
                  {% for arg in m.argument %}
                    <li>
                      <b>{{arg.get('name')}}</b> <span class="var-meta">{{arg.get('dataType')}}{% if arg.array|length>0 %}[]{% endif %}</span>
                      {% if arg.documentation|length>0 %}
                        <div class="doc"><span class="label label-doc">Doc</span>
                          {{arg.documentation|node_text_contents_to_string}}
                        </div>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}

              {% if m.returnvalue|length>0 %}
                <br/>
                Returns:
                <ul>
                  {% for rv in m.returnvalue %}
                    <li>
                      <b>{{rv.get('name')}}</b> <span class="var-meta">{{rv.get('dataType')}}{% if rv.array|length>0 %}[]{% endif %}</span>
                      {% if rv.documentation|length>0 %}
                        <div class="doc"><span class="label label-doc">Doc</span>
                          {{rv.documentation|node_text_contents_to_string}}
                        </div>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  {% else %}
    <p class="no-components">Configuration-only class — no OPC UA variables or methods at runtime.</p>
  {% endif %}
  {% if cls.hasobjects|length>0 %}
    <div class="children">
    Children:
    {% for ho in cls.hasobjects %}
      <a href="#class_{{ho.get('class')}}">{{ho.get('class')}}</a>
    {% endfor %}
    </div>
  {% endif %}
{% endfor %}

<footer style="margin-top: 3em; padding-top: 1em; border-top: 1px solid #ddd; text-align: center; color: #aaa; font-size: 0.8em;">
  Generated by <a href="https://github.com/quasar-team/quasar" style="color: #aaa;">quasar</a> &mdash; designed by <img src="data:image/png;base64," alt="PM" style="height: 18px; vertical-align: middle; opacity: 0.6; margin: 0 3px;"> Paris Moschovakos
</footer>
</body>
</html>
