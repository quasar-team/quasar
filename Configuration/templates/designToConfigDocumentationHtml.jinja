{% import 'headers.jinja' as headers %}
{% set this = designInspector.objectify_root() %}

{% macro writeRestrictions(containingClassName, objectName, what) %}
  {% set restrictions=designInspector.get_restrictions(containingClassName, objectName, what) %}

  {% if restrictions|length>0 %}
    <div class="restrictions"><span class="label label-restrictions">Restrictions</span>
      {% set restrictionType = oracle.classify_xsd_restrictions(restrictions) %}
      {% if restrictionType == 'enumeration' %}
        Enumeration:
        {% for restriction in restrictions -%}
          <code>{{restriction[1]}}{{'|' if not loop.last}}</code>
        {%- endfor %}
      {% elif restrictionType == 'pattern' %}
        Pattern:
        {% for restriction in restrictions -%}
          <code>{{restriction[1]}}</code>
        {% endfor %}
      {% elif restrictionType == 'bounds' %}
        Bounds:
        <code>
        {% for restriction in restrictions|sort(attribute=0, reverse=True) -%}
          {% if restriction[0] == 'minExclusive' %}
            {{boundsRestrictionPrefix}}{{objectName}} &gt; {{restriction[1]}}
          {% endif %}
          {% if restriction[0] == 'maxExclusive' %}
            {{boundsRestrictionPrefix}}{{objectName}} &lt; {{restriction[1]}}
          {% endif %}
          {% if restriction[0] == 'minInclusive' %}
            {{boundsRestrictionPrefix}}{{objectName}} &gt;= {{restriction[1]}}
          {% endif %}
          {% if restriction[0] == 'maxInclusive' %}
            {{boundsRestrictionPrefix}}{{objectName}} &lt;= {{restriction[1]}}
          {% endif %}
          {{' AND ' if not loop.last}}
        {% endfor %}
        </code>
      {% endif %}
    </div>
  {% endif %}
{% endmacro %}

{% macro writeCacheVarOrConfigEntry(containingClassName, elementObject, what) %}
  {% set objectName = elementObject.get('name') %}
  {% set objectType = elementObject.get('dataType') %}
  <b>{{objectName}}</b>
  <span class="type-badge">{{objectType}}</span>
  {% if elementObject.get('defaultValue') %}
    <span class="optional-badge">optional, default: <code>{{elementObject.get('defaultValue')}}</code></span>
  {% else %}
    <span class="mandatory-badge">mandatory</span>
  {% endif %}
  {% set docElements = designInspector.objectifyDocumentation(containingClassName, objectName) %}
  {% if docElements|length > 0 %}
    <div class="doc"><span class="label label-doc">Doc</span>
      {% for docElement in docElements %}
        {{ designInspector.strip_documentation_tag(docElement) }}
      {% endfor %}
      {# Add to the docs the enumeration documentation, if any. #}
      {% if what == 'configentry' %}
        {% set configEntryObjectified = designInspector.objectify_config_entries(containingClassName, "[@name='" + objectName + "']")[0] %}
        {% set enumerationValuesWithDocs = designInspector.xpath_relative_to_object(configEntryObjectified, 'd:configRestriction/d:restrictionByEnumeration/d:enumerationValue[d:documentation]') %}
        {% if enumerationValuesWithDocs|length > 0 %}
          <ul>
          {% for enumerationValue in designInspector.xpath_relative_to_object(configEntryObjectified, 'd:configRestriction/d:restrictionByEnumeration/d:enumerationValue') %}
            <li><code>{{enumerationValue.get('value')}}</code>:
              {% if enumerationValue.getchildren()|length > 0 %}
                {{ designInspector.strip_documentation_tag(enumerationValue.getchildren()[0]) }}
              {% else %}
                <b>To the developer: complete this documentation entry in your Design.</b>
              {% endif %}
            </li>
          {% endfor %}
          </ul>
        {% endif %}
      {% endif %}
    </div>
  {% endif %}
  {{ writeRestrictions(containingClassName, objectName, what) }}
{% endmacro %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Configuration documentation — {{designInspector.getProjectName()}}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; max-width: 960px; margin: 0 auto; padding: 1em; color: #333; }
    h1 { border-bottom: 2px solid #4a90d9; padding-bottom: 0.3em; }
    h2 { border-top: 2px solid #ddd; padding-top: 0.8em; margin-top: 1.5em; }
    a { color: #4a90d9; text-decoration: none; }
    a:hover { text-decoration: underline; }
    code { background: #f4f4f4; padding: 1px 4px; border-radius: 3px; font-size: 0.9em; }
    li { margin-bottom: 10pt; }
    .top-link { font-size: 0.8em; float: right; }
    .jump-index { margin: 1em 0; }
    .jump-index a { display: inline-block; margin: 2px 6px 2px 0; padding: 2px 8px; background: #f0f4f8; border-radius: 3px; font-size: 0.9em; }
    .type-badge { font-size: 0.85em; color: #666; }
    .optional-badge { font-size: 0.85em; color: #888; }
    .mandatory-badge { font-size: 0.85em; color: #c44; font-weight: bold; }
    .label { font-weight: bold; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.5px; margin-right: 0.5em; }
    .label-doc { color: #3366aa; }
    .label-restrictions { color: #aa3333; }
    .doc { background-color: #f0f4fa; border-left: 3px solid #4a90d9; padding: 6px 10px; margin: 4px 0; }
    .restrictions { background-color: #fef0f0; border-left: 3px solid #cc4444; padding: 6px 10px; margin: 4px 0; }
    .note { background-color: #fff3e0; border-left: 3px solid #e6a020; padding: 6px 10px; margin: 4px 0; }
    .children { margin-top: 0.5em; }
    .children a { display: inline-block; margin: 2px 6px 2px 0; padding: 2px 8px; background: #f0f4f8; border-radius: 3px; font-size: 0.9em; }
  </style>
</head>
<body>
  <h1>Configuration documentation for {{designInspector.getProjectName()}}</h1>

  <div class="jump-index">
  {% for className in designInspector.get_names_of_all_classes()|sort() %}
    {% set parentObjects = designInspector.objectifyAllParents(className, restrict_to_by_configuration=True) %}
    {% if parentObjects|length > 0 %}
      <a href="#class_{{className}}">{{className}}</a>
    {% endif %}
  {% endfor %}
  </div>

  {% for className in designInspector.get_names_of_all_classes()|sort() %}
    {% set parentObjects = designInspector.objectifyAllParents(className, restrict_to_by_configuration=True) %}
    {% if parentObjects|length > 0 %}
      <h2 id="class_{{className}}">{{className}} <a href="#" class="top-link">[top]</a></h2>
      {% set documentation = designInspector.objectifyDocumentation(className) %}
      {% if documentation %}
        <div class="doc"><span class="label label-doc">Doc</span>
          {% for docElement in documentation %}
            {{ designInspector.strip_documentation_tag(docElement) }}
          {% endfor %}
        </div>
      {% endif %}
      {% if designInspector.is_class_always_singleton(className) %}
        <div class="note"><span class="label">Note</span>
          This class is a singleton, do not declare it more than once.
        </div>
        {% if designInspector.get_class_default_instance_name(className) != None %}
          <div class="note"><span class="label">Note</span>
            The <code>name</code> attribute defaults to <code>{{designInspector.get_class_default_instance_name(className)}}</code>.
          </div>
        {% endif %}
      {% endif %}

      <ul>
      {% set configEntries= designInspector.objectify_config_entries(className) %}
      {% for configEntry in configEntries %}
        <li>
        {{ writeCacheVarOrConfigEntry(className, configEntry, "configentry") }}
        </li>
      {% endfor %}

      {% set configuredCacheVars = designInspector.objectify_cache_variables(className, restrict_by="[@initializeWith='configuration']") %}
      {% for cacheVar in configuredCacheVars %}
        <li>
        {{ writeCacheVarOrConfigEntry(className, cacheVar, "cachevariable") }}
        </li>
      {% endfor %}
      </ul>

      <div class="children">
        Children:
        <a href="#class_CalculatedVariable">CalculatedVariable</a>
        <a href="#class_FreeVariable">FreeVariable</a>
        {% for hasObject in designInspector.get_class_has_objects(className) %}
          {% if hasObject.get('instantiateUsing')=='configuration' %}
            <a href="#class_{{hasObject.get('class')}}">{{hasObject.get('class')}}</a>
          {% endif %}
        {% endfor %}
      </div>

    {% endif %}
  {% endfor %}

  <h2 id="class_CalculatedVariable">CalculatedVariable <a href="#" class="top-link">[top]</a></h2>
  <div class="doc"><span class="label label-doc">Doc</span>
  A CalculatedVariable is a synthetic variable computed from other address-space variables.
  Declare under any object in the configuration file.
  </div>
  <ul>
    <li><b>name</b> — the last part of the OPC UA address</li>
    <li><b>value</b> — analytical formula, e.g. <code>x.y^2</code> to compute the square of variable <code>x.y</code></li>
  </ul>
  See <code>CalculatedVariables/doc/CalculatedVariables.html</code> in the quasar documentation for details.

  <h2 id="class_CalculatedVariableGenericFormula">CalculatedVariableGenericFormula <a href="#" class="top-link">[top]</a></h2>
  <div class="doc"><span class="label label-doc">Doc</span>
  A generalized formula template used with the <code>$applyGenericFormula</code> operator
  to instantiate CalculatedVariables, reducing redundancy. Must be declared at the top of the configuration file.
  </div>

  <h2 id="class_FreeVariable">FreeVariable <a href="#" class="top-link">[top]</a></h2>
  <div class="doc"><span class="label label-doc">Doc</span>
  An OPC UA variable that can be added anywhere in the address space. Not governed by the server Design —
  always writable by any OPC UA client.
  </div>
  <ul>
    <li><b>name</b> — required</li>
    <li><b>type</b> — one of: Boolean, Byte, SByte, UInt16, Int16, UInt32, Int32, UInt64, Int64, Float, Double, String</li>
    <li><b>initialValue</b> — optional</li>
  </ul>

<footer style="margin-top: 3em; padding-top: 1em; border-top: 1px solid #ddd; text-align: center; color: #aaa; font-size: 0.8em;">
  Generated by <a href="https://github.com/quasar-team/quasar" style="color: #aaa;">quasar</a> &mdash; designed by <img src="data:image/png;base64," alt="PM" style="height: 18px; vertical-align: middle; opacity: 0.6; margin: 0 3px;"> Paris Moschovakos
</footer>
</body>
</html>
